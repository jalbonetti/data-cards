<!-- ============================================================
     BETTOR RESULTS — TABBED SHELL
     Paste this whole block into ONE Webflow Embed (custom code box).

     SETUP (2 steps):
     1) Host the six widget files somewhere that serves real HTML and allows
        framing — GitHub Pages or jsDelivr. (raw.githubusercontent.com does NOT work.)
        GitHub Pages:  https://jalbonetti.github.io/data-cards/baseball/matchups.html
        jsDelivr:      https://cdn.jsdelivr.net/gh/YOURNAME/REPO@main/matchups.html
     2) Replace the six data-src URLs below with your hosted URLs.

     Notes:
       • Iframes are transparent, so your page's purple background shows through.
       • Only the tab you open loads (lazy) — saves six simultaneous Supabase pulls.
       • Adjust --bbtab-h to taste (widget scrolls inside its own frame).
     ============================================================ -->
<div class="bbtabs" id="bbtabs">
  <div class="bbtabs-bar" role="tablist" aria-label="Betting data">
    <button class="bbtab on" role="tab" aria-selected="true"  data-src="https://jalbonetti.github.io/data-cards/baseball/matchups.html"   title="Matchups">Matchups</button>
    <button class="bbtab"    role="tab" aria-selected="false" data-src="https://jalbonetti.github.io/data-cards/baseball/batterClearances.html" title="Batter Clearances">Batter Clearances</button>
    <button class="bbtab"    role="tab" aria-selected="false" data-src="https://jalbonetti.github.io/data-cards/baseball/pitcherClearances.html"    title="Pitcher Clearances">Pitcher Clearances</button>
    <button class="bbtab"    role="tab" aria-selected="false" data-src="https://jalbonetti.github.io/data-cards/baseball/evBets.html"      title="Prop Odds (+EV)">Prop Odds</button>
    <button class="bbtab"    role="tab" aria-selected="false" data-src="https://jalbonetti.github.io/data-cards/baseball/dfsDK.html"     title="DraftKings DFS">DraftKings DFS</button>
    <button class="bbtab"    role="tab" aria-selected="false" data-src="https://jalbonetti.github.io/data-cards/baseball/dfsFD.html"     title="FanDuel DFS">FanDuel DFS</button>
  </div>
  <div class="bbtabs-stage" id="bbtabsStage"><!-- iframes injected here --></div>
</div>

<style>
  /* Scoped to .bbtabs so nothing leaks onto the rest of your Webflow page. */
  .bbtabs{--bbtab-h:86vh;--bbtab-min:560px;--accent:#06b6d4;--accent-dark:#0891b2;
    --bar-bg:rgba(20,12,30,.55);--tab-ink:rgba(255,255,255,.92);--tab-ink-off:rgba(255,255,255,.62);
    --font:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;
    font-family:var(--font);max-width:1180px;margin:0 auto;}
  .bbtabs *,.bbtabs *::before,.bbtabs *::after{box-sizing:border-box;}
  .bbtabs-bar{position:sticky;top:0;z-index:20;display:flex;gap:6px;overflow-x:auto;-webkit-overflow-scrolling:touch;
    padding:8px;background:var(--bar-bg);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);
    border-radius:12px;scrollbar-width:none;}
  .bbtabs-bar::-webkit-scrollbar{display:none;}
  .bbtab{flex:0 0 auto;border:1px solid rgba(255,255,255,.18);background:rgba(255,255,255,.06);
    color:var(--tab-ink-off);font-family:inherit;font-size:13px;font-weight:700;white-space:nowrap;
    padding:9px 14px;border-radius:9px;cursor:pointer;transition:background .12s ease,color .12s ease,border-color .12s ease;}
  .bbtab:hover{color:var(--tab-ink);background:rgba(255,255,255,.12);}
  .bbtab.on{background:var(--accent);border-color:var(--accent-dark);color:#fff;}
  .bbtab:focus-visible{outline:2px solid #fff;outline-offset:2px;}
  @media (prefers-reduced-motion:reduce){.bbtab{transition:none;}}
  .bbtabs-stage{position:relative;margin-top:10px;}
  .bbtabs-frame{display:none;width:100%;height:var(--bbtab-h);min-height:var(--bbtab-min);
    border:0;background:transparent;border-radius:12px;}
  .bbtabs-frame.on{display:block;}
</style>

<script>
(function(){
  var root = document.getElementById('bbtabs');
  if(!root || root.dataset.init) return;        // guard against double-init
  root.dataset.init = '1';
  var bar = root.querySelector('.bbtabs-bar');
  var stage = root.querySelector('#bbtabsStage');
  var tabs = Array.prototype.slice.call(bar.querySelectorAll('.bbtab'));
  var frames = [];

  function activate(i){
    tabs.forEach(function(t,j){
      var on = j===i;
      t.classList.toggle('on', on);
      t.setAttribute('aria-selected', on ? 'true':'false');
      t.tabIndex = on ? 0 : -1;
    });
    frames.forEach(function(f,j){ if(f) f.classList.toggle('on', j===i); });
    // lazy-load: create the iframe only the first time its tab is opened
    if(!frames[i]){
      var src = tabs[i].getAttribute('data-src');
      var f = document.createElement('iframe');
      f.className = 'bbtabs-frame on';
      f.setAttribute('loading','lazy');
      f.setAttribute('title', tabs[i].getAttribute('title') || tabs[i].textContent);
      f.src = src;
      stage.appendChild(f);
      frames[i] = f;
    }
  }

  tabs.forEach(function(tab,i){
    tab.tabIndex = i===0 ? 0 : -1;
    tab.addEventListener('click', function(){ activate(i); });
    tab.addEventListener('keydown', function(e){
      var n = tabs.length, j = i;
      if(e.key==='ArrowRight'){ j=(i+1)%n; } else if(e.key==='ArrowLeft'){ j=(i-1+n)%n; }
      else { return; }
      e.preventDefault(); tabs[j].focus(); activate(j);
    });
  });

  activate(0);   // open + load the first tab
})();
</script>
